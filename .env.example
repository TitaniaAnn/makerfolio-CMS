# Template .env for a fresh install. The installer (web wizard or bin/install.php)
# renders a populated copy of this file. Copy by hand for manual setups.

# ---------------------------------------------------------------------------
# Database — the DB and user must already exist; the installer doesn't create
# them. On shared hosting, create both via cPanel first.
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_NAME=pottery_portfolio
DB_USER=
DB_PASS=

# ---------------------------------------------------------------------------
# Site
#   Used for OAuth callback URLs, mailer From-line links, Stripe redirects.
#   For local dev: http://localhost:8088 (Docker) or http://localhost:8000 (php -S).
# ---------------------------------------------------------------------------
SITE_URL=https://yourdomain.com

# ---------------------------------------------------------------------------
# GitHub OAuth (OPTIONAL — manage via /admin/settings/auth.php after install)
#
# Auth provider credentials live in the `settings` DB table now, not .env.
# Leave these blank unless you're (a) doing a brand-new Docker boot and want
# the auto-migrate entrypoint to copy them into settings on first boot, or
# (b) running bin/install.php without the corresponding --github-* flags.
#
# Setup: https://github.com/settings/developers → New OAuth App,
#   callback URL: {SITE_URL}/admin/auth/callback.php
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ALLOWED_GITHUB_USERS=

# ---------------------------------------------------------------------------
# Stripe (optional — leave blank to disable payments; storefront falls back
# to "Enquire" links for buyers.)
# ---------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Instagram (optional — manage via /admin/social/tokens.php after login.)
# ---------------------------------------------------------------------------
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Trusted reverse proxies (optional — comma-separated IPs).
# Auth::clientIp() only honors X-Forwarded-For when REMOTE_ADDR matches one
# of these. Loopback (127.0.0.1, ::1) is always trusted. Leave blank for
# direct-exposed PHP-FPM/Apache. Add Cloudflare / your CDN's egress IPs if
# you're behind one and want rate-limiting to see real client IPs.
# ---------------------------------------------------------------------------
TRUSTED_PROXIES=
