# Copy to .env.docker and fill in real OAuth + Stripe values as needed.
# The web service reads this via compose's env_file directive.

# Database — values match compose.yml's mysql service
DB_HOST=db
DB_NAME=pottery_portfolio
DB_USER=pottery
DB_PASS=potterypw

# Site URL for OAuth callback, mailer links, Stripe redirects
SITE_URL=http://localhost:8088

# GitHub OAuth — these MUST be present (ALLOWED_GITHUB_USERS fails closed with no fallback).
# For local boot without real OAuth, stubs satisfy the presence check; the login flow
# itself will only succeed with real values and a matching callback URL registered on GitHub.
GITHUB_CLIENT_ID=dev-stub
GITHUB_CLIENT_SECRET=dev-stub
ALLOWED_GITHUB_USERS=your-github-username

# Stripe — leave blank/placeholder to keep STRIPE_ENABLED=false (storefront falls back to Enquire).
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Instagram (optional) — manage via /admin/social/tokens.php once logged in.
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=
